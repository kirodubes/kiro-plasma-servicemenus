[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=image/webp;
Icon=image-webp
Actions=jpg
X-KDE-Priority=TopLevel
X-KDE-StartupNotify=false
X-KDE-Submenu=Convert to
X-KDE-Submenu[it]=Converti in

[Desktop Action jpg]
Name=JPEG image
Name[it]=Immagine JPEG
Icon=image-jpeg
Exec=filename=%f; magick "$filename" -background white -alpha remove -alpha off -quality 90 "${filename%.*}.jpg"
