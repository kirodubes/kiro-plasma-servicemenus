[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=image/png;
Icon=image-png
Actions=webp
X-KDE-Priority=TopLevel
X-KDE-StartupNotify=false
X-KDE-Submenu=Convert to
X-KDE-Submenu[it]=Converti in

[Desktop Action webp]
Name=WebP image
Name[it]=Immagine WebP
Icon=image-webp
Exec=filename=%f; magick "$filename" "${filename%.*}.webp"
